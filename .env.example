# Example environment file for deployment
# Copy this to .env.dev and .env.sit on your server and fill in actual values

# MySQL Root Password (should be strong)
MYSQL_ROOT_PASSWORD=your_strong_root_password

# Application Database User
MYSQL_USER=fairshare

# Application Database Password
MYSQL_PASSWORD=your_app_db_password

# Database Name
MYSQL_DATABASE=fairshare

# Docker Compose Project Name (used for container naming)
COMPOSE_PROJECT_NAME=fairshare-dev
