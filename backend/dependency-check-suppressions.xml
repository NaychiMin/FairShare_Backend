<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">

    <!-- Tomcat -->
    <suppress>
        <notes>Embedded Tomcat used by Spring Boot</notes>
        <packageUrl>pkg:maven/org.apache.tomcat.embed/tomcat-embed-core</packageUrl>
    </suppress>

    <suppress>
        <notes>Tomcat websocket module</notes>
        <packageUrl>pkg:maven/org.apache.tomcat.embed/tomcat-embed-websocket</packageUrl>
    </suppress>

    <suppress>
        <notes>Tomcat EL module</notes>
        <packageUrl>pkg:maven/org.apache.tomcat.embed/tomcat-embed-el</packageUrl>
    </suppress>

    <!-- Swagger UI DOMPurify -->
    <suppress>
        <notes>DOMPurify inside Swagger UI frontend bundle</notes>
        <packageUrl>pkg:javascript/DOMPurify</packageUrl>
    </suppress>

</suppressions>